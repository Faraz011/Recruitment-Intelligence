# Rename this to .env and fill in your actual values

# Get HuggingFace API Key for FREE:
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a free account
# 3. Click "New token"
# 4. Give it a name, select "read" access
# 5. Copy the token
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Get Supabase credentials: Go to Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
