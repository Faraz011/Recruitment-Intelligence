# Rename this to .env and fill in your actual values

# Get Groq API Key (FREE with generous limits):
# 1. Go to https://console.groq.com
# 2. Sign up for a free account
# 3. Click "API Keys" in the left sidebar
# 4. Create a new API key
# 5. Copy the key (format: gsk_xxxxxxxxxxxxxxx)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get Supabase credentials:
# 1. Go to https://supabase.com
# 2. Create a new project or use existing one
# 3. Navigate to Project Settings > API
# 4. Copy the Project URL (SUPABASE_URL)
# 5. Copy the Service Role Secret (SUPABASE_SERVICE_KEY) - Keep this SECRET!
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
